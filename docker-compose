services:

  db:
    image: mysql:8.4
    container_name: mamamia-db
    restart: unless-stopped
    environment:
      MYSQL_DATABASE: mamamia
      MYSQL_USER: mamamia
      MYSQL_PASSWORD: mamamia123
      MYSQL_ROOT_PASSWORD: root123
    ports:
      - "3306:3306"
    volumes:
      - db_data:/var/lib/mysql
      # Si tienes scripts .sql en /database, se ejecutan solos al crear el contenedor
      - ./database:/docker-entrypoint-initdb.d:ro
    healthcheck:
      test: ["CMD", "mysqladmin", "ping", "-h", "localhost"]
      interval: 10s
      timeout: 5s
      retries: 5

  backend:
    build:
      context: .
      dockerfile: Dockerfile
    container_name: mamamia-backend
    restart: unless-stopped
    depends_on:
      db:
        condition: service_healthy
    environment:
      SPRING_DATASOURCE_URL: jdbc:mysql://db:3306/mamamia?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
      SPRING_DATASOURCE_USERNAME: mamamia
      SPRING_DATASOURCE_PASSWORD: mamamia123
      SPRING_JPA_HIBERNATE_DDL_AUTO: update
    ports:
      - "8080:8080"

  frontend:
    image: nginx:alpine
    container_name: mamamia-frontend
    restart: unless-stopped
    depends_on:
      - backend
    volumes:
      - ./frontend:/usr/share/nginx/html:ro
    ports:
      - "8081:80"

volumes:
  db_data:
